<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Pre Flight Check DJI T50</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f2f2f2;
    }

    .container {
      max-width: 520px;
      margin: 30px auto;
      background: #fff;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    h2 {
      text-align: center;
    }

    label {
      display: block;
      margin-top: 10px;
      font-weight: bold;
    }

    input, select {
      width: 100%;
      padding: 8px;
      margin-top: 5px;
    }

    /* 🔥 CHECKLIST ROW */
    .check-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 10px 0;
      border-bottom: 1px solid #eee;
    }

    .check-name {
      font-weight: bold;
      font-size: 14px;
      flex: 1;
    }

    .check-options {
      display: flex;
      gap: 6px;
    }

    .check-options input {
      display: none;
    }

    .check-options label {
      padding: 4px 10px;
      border-radius: 6px;
      cursor: pointer;
      font-weight: bold;
      font-size: 12px;
      border: 1px solid #ccc;
      user-select: none;
      transition: 0.2s;
    }

    /* OK = HIJAU */
    .check-options input.ok:checked + label.ok {
      background: #28a745;
      color: white;
      border-color: #28a745;
    }

    /* NOT OK = MERAH */
    .check-options input.notok:checked + label.notok {
      background: #dc3545;
      color: white;
      border-color: #dc3545;
    }

    button {
      margin-top: 20px;
      width: 100%;
      padding: 10px;
      background: green;
      color: white;
      border: none;
      cursor: pointer;
      border-radius: 6px;
    }

    button:hover {
      background: darkgreen;
    }

    #result {
      margin-top: 15px;
      color: green;
      font-weight: bold;
      text-align: center;
    }
  </style>
</head>

<body>

<div class="container">
  <h2>Pre Flight Check DJI T50</h2>

  <form id="flightForm">

    <label>Tanggal</label>
    <input type="date" required>

    <label>Nama Operator</label>
    <select required>
      <option value="">Pilih</option>
      <option>Aziz</option>
      <option>Banu</option>
      <option>Sahrul</option>
      <option>Afridus</option>
      <option>Rikson</option>
      <option>Aqmal</option>
      <option>Kifli</option>
    </select>

    <label>Unit Code</label>
    <select required>
      <option value="">Pilih</option>
      <option>DJIT50-01</option>
      <option>DJIT50-02</option>
      <option>DJIT50-03</option>
      <option>DJIT50-04</option>
      <option>DJIT50-05</option>
      <option>DJIT50-06</option>
      <option>DJIT100-01</option>
    </select>

    <label>Paddock</label>
    <input type="text" required>

    <label>Kegiatan</label>
    <input type="text" required>

    <!-- CHECKLIST -->
    <div class="check-row">
      <div class="check-name">Propeller Check</div>
      <div class="check-options">
        <input type="radio" name="propeller" id="prop-ok" class="ok">
        <label for="prop-ok" class="ok">OK</label>

        <input type="radio" name="propeller" id="prop-no" class="notok">
        <label for="prop-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Battery Check</div>
      <div class="check-options">
        <input type="radio" name="battery" id="bat-ok" class="ok">
        <label for="bat-ok" class="ok">OK</label>

        <input type="radio" name="battery" id="bat-no" class="notok">
        <label for="bat-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Mission Check</div>
      <div class="check-options">
        <input type="radio" name="mission" id="mis-ok" class="ok">
        <label for="mis-ok" class="ok">OK</label>

        <input type="radio" name="mission" id="mis-no" class="notok">
        <label for="mis-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Parameter Check</div>
      <div class="check-options">
        <input type="radio" name="parameter" id="par-ok" class="ok">
        <label for="par-ok" class="ok">OK</label>

        <input type="radio" name="parameter" id="par-no" class="notok">
        <label for="par-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">RTK Check</div>
      <div class="check-options">
        <input type="radio" name="rtk" id="rtk-ok" class="ok">
        <label for="rtk-ok" class="ok">OK</label>

        <input type="radio" name="rtk" id="rtk-no" class="notok">
        <label for="rtk-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Wind Check</div>
      <div class="check-options">
        <input type="radio" name="wind" id="wind-ok" class="ok">
        <label for="wind-ok" class="ok">OK</label>

        <input type="radio" name="wind" id="wind-no" class="notok">
        <label for="wind-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Tanki Check</div>
      <div class="check-options">
        <input type="radio" name="tanki" id="tan-ok" class="ok">
        <label for="tan-ok" class="ok">OK</label>

        <input type="radio" name="tanki" id="tan-no" class="notok">
        <label for="tan-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Chemical Check</div>
      <div class="check-options">
        <input type="radio" name="chemical" id="chem-ok" class="ok">
        <label for="chem-ok" class="ok">OK</label>

        <input type="radio" name="chemical" id="chem-no" class="notok">
        <label for="chem-no" class="notok">Not OK</label>
      </div>
    </div>

    <div class="check-row">
      <div class="check-name">Obstacle Check</div>
      <div class="check-options">
        <input type="radio" name="obstacle" id="obs-ok" class="ok">
        <label for="obs-ok" class="ok">OK</label>

        <input type="radio" name="obstacle" id="obs-no" class="notok">
        <label for="obs-no" class="notok">Not OK</label>
      </div>
    </div>

    <button type="submit">Submit</button>
  </form>

  <div id="result"></div>
</div>

<script>
  document.getElementById("flightForm").addEventListener("submit", function(e){
    e.preventDefault();
    document.getElementById("result").innerText = "Data berhasil disimpan!";
  });
</script>

</body>
</html>
